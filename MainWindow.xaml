<Window x:Class="LogMan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LogMan"
        xmlns:vm="clr-namespace:LogMan.ViewModels"
        mc:Ignorable="d"
        Title="LogMan - Unified Log Viewer" Height="600" Width="1000"
        Icon="/logman.ico">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <Style x:Key="LevelFilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="Background" Value="#FCFDFF"/>
            <Setter Property="BorderBrush" Value="#BFCBDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              Content="{TemplateBinding Content}"
                                              TextElement.FontWeight="SemiBold"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EAF2FF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#7AA2D6"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#9FB4CA"/>
                                <Setter TargetName="Chrome" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4C7EF3"/>
                                <Setter TargetName="Chrome" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" IsLocked="True">
            <ToolBar>
                <Button Command="{Binding LoadFileCommand}" ToolTip="Open .evtx File">
                    <TextBlock Text="📂 Open"/>
                </Button>
                <Separator />
                <Button Command="{Binding ClearCommand}" ToolTip="Clear All Logs">
                    <TextBlock Text="❌ Clear"/>
                </Button>
                <Separator />
                <Button Command="{Binding ExportCommand}" ToolTip="Export Filtered Logs to CSV/JSON">
                    <TextBlock Text="📤 Export"/>
                </Button>
                <Separator />
                <Button Command="{Binding ClearHighlightsCommand}" ToolTip="Clear All Highlighting">
                    <TextBlock Text="Clear Highlights"/>
                </Button>
                <Separator />
                
                <Menu Background="Transparent">
                    <MenuItem Header="Monitor" ToolTip="Select Live Log Sources" IsEnabled="{Binding CanManageSources}">
                        <MenuItem.ItemsSource>
                            <Binding Path="LogSources"/>
                        </MenuItem.ItemsSource>
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding DisplayName}"/>
                                <Setter Property="IsCheckable" Value="True"/>
                                <Setter Property="IsChecked" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="StaysOpenOnClick" Value="True"/>
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                </Menu>

                <Separator />
                <TextBlock Text="Add Remote: " VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Width="120" Text="{Binding NewMachineName, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" IsEnabled="{Binding CanManageSources}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding AddMachineCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Command="{Binding AddMachineCommand}" ToolTip="Add Remote Machine" Margin="5,0">
                    <TextBlock Text="➕"/>
                </Button>
                <Separator />

                <ToggleButton IsChecked="{Binding IsLiveCaptureEnabled}" 
                              IsEnabled="{Binding CanManageSources}"
                              ToolTip="Start/Stop Live Capture"
                              Style="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Margin="0,1,5,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="Black"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLiveCaptureEnabled}" Value="True">
                                            <Setter Property="Fill" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Live" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <Separator />
                <TextBlock Text="Search: " VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Width="200" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            </ToolBar>
            <ToolBar>
                <TextBlock Text="Show Levels:"
                           Margin="5,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#475467"/>
                <ToggleButton Style="{StaticResource LevelFilterToggleStyle}"
                              IsChecked="{Binding ShowCritical, Mode=TwoWay}"
                              Content="Critical"
                              ToolTip="Show or hide Critical events in the grid."/>
                <ToggleButton Style="{StaticResource LevelFilterToggleStyle}"
                              IsChecked="{Binding ShowError, Mode=TwoWay}"
                              Content="Error"
                              ToolTip="Show or hide Error events in the grid."/>
                <ToggleButton Style="{StaticResource LevelFilterToggleStyle}"
                              IsChecked="{Binding ShowWarning, Mode=TwoWay}"
                              Content="Warning"
                              ToolTip="Show or hide Warning events in the grid."/>
                <ToggleButton Style="{StaticResource LevelFilterToggleStyle}"
                              IsChecked="{Binding ShowInfo, Mode=TwoWay}"
                              Content="Info"
                              ToolTip="Show or hide Informational events in the grid."/>
                <ToggleButton Style="{StaticResource LevelFilterToggleStyle}"
                              IsChecked="{Binding ShowVerbose, Mode=TwoWay}"
                              Content="Verbose"
                              ToolTip="Show or hide Verbose events in the grid."/>
            </ToolBar>
        </ToolBarTray>

        <!-- Main Grid -->
        <DataGrid Grid.Row="1" 
                  x:Name="LogGrid"
                  ItemsSource="{Binding LogEntriesView}"
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Extended"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  RowHeight="25">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Background" Value="{Binding HighlightIndex, Converter={x:Static local:HighlightIndexToBrushConverter.Instance}}"/>
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="LogGridRow_PreviewMouseRightButtonDown"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Highlight Event"
                              Command="{Binding PlacementTarget.DataContext.HighlightEventCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="Clear Highlights"
                              Command="{Binding PlacementTarget.DataContext.ClearHighlightsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator />
                    <MenuItem Header="Search Bing for Event ID"
                              Command="{Binding PlacementTarget.DataContext.SearchBingByIdCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="Search Bing for Message"
                              Command="{Binding PlacementTarget.DataContext.SearchBingByMessageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator />
                    <MenuItem Header="Copy Event"
                              Command="{Binding PlacementTarget.DataContext.CopyEventCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}" Width="180"/>
                <DataGridTextColumn Header="Machine" Binding="{Binding MachineName}" Width="100"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                    <Setter Property="Foreground" Value="Orange"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Log Name" Binding="{Binding LogName}" Width="100"/>
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="150"/>
                <DataGridTextColumn Header="Event ID" Binding="{Binding EventId}" Width="70"/>
                <DataGridTextColumn Header="Message" Binding="{Binding MessagePreview}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="TextWrapping" Value="NoWrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="LightGray"/>

        <!-- Details Pane -->
        <TabControl Grid.Row="3">
            <TabItem Header="Message">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F3F3F3" BorderBrush="LightGray" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="Time: " FontWeight="SemiBold" Foreground="#666"/>
                            <TextBlock Text="{Binding ElementName=LogGrid, Path=SelectedItem.Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}" Margin="0,0,15,0"/>
                            
                            <TextBlock Text="Machine: " FontWeight="SemiBold" Foreground="#666"/>
                            <TextBlock Text="{Binding ElementName=LogGrid, Path=SelectedItem.MachineName}" Margin="0,0,15,0"/>
                            
                            <TextBlock Text="ID: " FontWeight="SemiBold" Foreground="#666"/>
                            <TextBlock Text="{Binding ElementName=LogGrid, Path=SelectedItem.EventId}"/>
                        </StackPanel>
                    </Border>
                    <TextBox Grid.Row="1" 
                             Text="{Binding ElementName=LogGrid, Path=SelectedItem.Message, Mode=OneWay}" 
                             TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" 
                             IsReadOnly="True" 
                             BorderThickness="0"
                             Padding="10"
                             FontFamily="Consolas"
                             FontSize="12.5"
                             Background="#FDFDFD"/>
                </Grid>
            </TabItem>
            <TabItem Header="Details">
                <TextBox Text="{Binding ElementName=LogGrid, Path=SelectedItem.RawData, Mode=OneWay}" 
                         TextWrapping="NoWrap" 
                         VerticalScrollBarVisibility="Auto" 
                         HorizontalScrollBarVisibility="Auto" 
                         IsReadOnly="True" 
                         BorderThickness="0" 
                         FontFamily="Consolas"
                         Padding="10"
                         Background="#FDFDFD"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Events: "/>
                    <TextBlock Text="{Binding FilteredCount}"/>
                    <TextBlock Text=" of "/>
                    <TextBlock Text="{Binding LogEntriesView.SourceCollection.Count}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <ProgressBar Width="100" Height="15" IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={x:Static local:BooleanToVisibilityConverter.Instance}}"/>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
